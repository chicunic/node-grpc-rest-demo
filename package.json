{
  "name": "node-grpc-rest-demo",
  "version": "1.0.0",
  "description": "Node.js template with gRPC and REST API support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "start": "node dist/index.js",
    "start:grpc": "node dist/grpc/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:grpc": "tsx watch src/grpc/server.ts",
    "check": "tsc --noEmit && biome check",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "grpc",
    "rest",
    "api",
    "template",
    "typescript",
    "nodejs"
  ],
  "author": "chicunic",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "grpc-health-check": "^2.1.0",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
