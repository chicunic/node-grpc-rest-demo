{
  "name": "node-grpc-rest-demo",
  "version": "1.0.0",
  "description": "Node.js template with gRPC and REST API support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "start": "node dist/index.js",
    "start:grpc": "node dist/grpc/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:grpc": "tsx watch src/grpc/server.ts",
    "check": "tsc --noEmit && biome check",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "grpc",
    "rest",
    "api",
    "template",
    "typescript",
    "nodejs"
  ],
  "author": "chicunic",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "grpc-health-check": "^2.1.0",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.7",
      "http-proxy-agent": ">=7.0.0"
    },
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "esbuild",
      "protobufjs"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
