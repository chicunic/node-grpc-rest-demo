{
  "name": "node-grpc-rest-demo",
  "version": "1.0.0",
  "description": "Node.js template with gRPC and REST API support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "start": "node dist/index.js",
    "start:grpc": "node dist/grpc/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:grpc": "tsx watch src/grpc/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.test.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --verbose",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch --verbose",
    "test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage --verbose",
    "test:integration": "NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/specs/integration --verbose",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "grpc",
    "rest",
    "api",
    "template",
    "typescript",
    "nodejs"
  ],
  "author": "chicunic",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "grpc-health-check": "^2.1.0",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@jest/globals": "^30.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
