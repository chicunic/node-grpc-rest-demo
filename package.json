{
  "name": "node-grpc-rest-demo",
  "version": "1.0.0",
  "description": "Node.js template with gRPC and REST API support",
  "license": "MIT",
  "author": "chicunic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chicunic/node-grpc-rest-demo.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "grpc",
    "rest",
    "api",
    "template",
    "typescript",
    "nodejs"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev:grpc": "tsx watch --env-file-if-exists=.env src/grpc/server.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "start:grpc": "tsx --env-file-if-exists=.env src/grpc/server.ts",
    "start:prod": "node --env-file-if-exists=.env dist/index.js",
    "proto:types": "proto-loader-gen-types --keepCase --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js --outDir=src/generated/proto api/proto/v1/*.proto && node scripts/proto-add-js-ext.mjs",
    "prebuild": "pnpm run proto:types",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check": "tsc && eslint . && prettier --check .",
    "fix": "eslint . --fix && prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@grpc/reflection": "^1.0.4",
    "@hono/node-server": "^2.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "grpc-health-check": "^2.1.0",
    "hono": "^4.12.18",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "esbuild",
      "protobufjs"
    ]
  }
}
